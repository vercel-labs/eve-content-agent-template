{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core"],
  "linter": {
    "rules": {
      "style": {
        // Eve derives tool/connection/skill names from filenames, and this project
        // uses snake_case (e.g. agent/tools/upload_asset.ts). Disable the kebab-case
        // filename rule so those names aren't flagged.
        "useFilenamingConvention": "off"
      }
    }
  }
}
